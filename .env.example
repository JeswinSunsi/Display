# Netlify site URL, no trailing slash
APP_URL=https://your-site-name.netlify.app

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# Generate long random values and set in Netlify environment variables
TOKEN_ENCRYPTION_KEY=replace_with_long_random_secret
OAUTH_STATE_SECRET=replace_with_long_random_secret
